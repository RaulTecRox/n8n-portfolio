    {
      "parameters": {
        "jsCode": "// Iterando sobre todos os itens recebidos\nconst resultado = items.map(item => {\n  const dados = item.json;  // Acessando os dados de cada item\n\n  // Acessando o campo de data de nascimento do beneficiário\n  const dataNascimento = dados.dataNascimento;\n\n  // Convertendo a data de nascimento para um objeto Date\n  const nascimento = new Date(dataNascimento);\n  const hoje = new Date();\n\n  // Calculando a diferença de anos\n  let idade = hoje.getFullYear() - nascimento.getFullYear();\n\n  // Verificando se o aniversário já passou neste ano\n  const mesAtual = hoje.getMonth();\n  const mesNascimento = nascimento.getMonth();\n  const diaAtual = hoje.getDate();\n  const diaNascimento = nascimento.getDate();\n\n  // Ajustando a idade caso o aniversário ainda não tenha ocorrido neste ano\n  if (mesAtual < mesNascimento || (mesAtual === mesNascimento && diaAtual < diaNascimento)) {\n    idade--;\n  }\n\n  // Retornando os dados completos junto com a idade calculada\n  return {\n    json: {\n      nomeBeneficiario: dados.nomeBeneficiario,\n      cpfBeneficiario: dados.cpfBeneficiario,\n      idade: idade,\n      beneficio: dados.beneficio,\n      situacao: dados.situacao,\n      especie: dados.especie\n    }\n  };\n});\n\n// Retornando todos os resultados processados\nreturn resultado;\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1680,
        100
      ],
      "id": "297ff406-83ba-42ea-9e3f-5c48f832d96a",
      "name": "Code2"
    },
    {
      "parameters": {
        "jsCode": "// A entrada no nó Filter é acessada via 'items'\nconst items = $input.all(); \n\n// Criação de um array para armazenar os resultados\nconst result = [];\n\nitems.forEach(item => {\n    let data;\n\n    try {\n        // O payload pode ser um JSON com ou sem a chave \"data\"\n        const parsedPayload = JSON.parse(item.json.payload);\n\n        // Verifica se o payload tem a chave \"data\" ou não\n        if (parsedPayload.statusCode === 200 && parsedPayload.data) {\n            data = parsedPayload.data;\n        } else {\n            // Caso contrário, trata como um objeto simples\n            data = [parsedPayload];  // Coloca o objeto em um array para processar da mesma forma\n        }\n\n        // Adicionar log para depuração\n        console.log('Parsed Payload:', parsedPayload);\n\n    } catch (error) {\n        // Se não conseguir fazer o parse, trata como dados inválidos\n        data = [];\n    }\n\n    // Verifica se 'data' é um array antes de tentar usar forEach\n    if (Array.isArray(data)) {\n        // Para cada item dentro do array 'data', extraímos o nome e telefone\n        data.forEach(entry => {\n            const nome = entry.NOME || \"Nome não disponível\";  // Checamos se o nome existe\n            const telefone = entry.TELEFONE || \"Telefone não disponível\";  // Checamos se o telefone existe\n            result.push({ NOME: nome, TELEFONE: telefone });  // Adiciona ao resultado\n        });\n    } else {\n        // Caso 'data' não seja um array (caso do objeto simples), tratamos de outra forma\n        const nome = data.NOME || \"Nome não disponível\";\n        const telefone = data.TELEFONE || \"Telefone não disponível\";\n        result.push({ NOME: nome, TELEFONE: telefone });\n    }\n});\n\n// Retorna os dados formatados\nreturn result.map(item => ({ json: item }));\n"
      },
