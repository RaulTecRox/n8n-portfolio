    {
      "parameters": {
        "jsCode": "// Criando um array para armazenar os resultados\nconst result = [];\n\n// Iterando por cada item em 'items'\nfor (const item of items) {\n  // Pegando o JSON da entrada de cada item\n  const data = JSON.parse(item.json.payload);\n\n  // Verificando se data é um array\n  if (Array.isArray(data)) {\n    // Iterando sobre os dados dentro de 'data'\n    for (const entry of data) {\n      const beneficiario = entry.Beneficiario;\n      const resumoFinanceiro = entry.ResumoFinanceiro;\n      const dadosBancarios = entry.DadosBancarios;\n\n      // Criando o objeto com todos os campos\n      const extractedData = {\n        // Beneficiario\n        nomeBeneficiario: beneficiario.Nome,\n        cpfBeneficiario: beneficiario.CPF,\n        dataNascimento: beneficiario.DataNascimento,\n        beneficio: beneficiario.Beneficio,\n        situacao: beneficiario.Situacao,\n        dib: beneficiario.DIB,\n        ddb: beneficiario.DDB,\n        nomeMae: beneficiario.NomeMae,\n        rg: beneficiario.Rg,\n        sexo: beneficiario.Sexo,\n        especie: beneficiario.Especie,\n        pa: beneficiario.PA,\n        rl: beneficiario.RL,\n        bloqueadoEmprestimo: beneficiario.BloqueadoEmprestimo,\n        permiteEmprestimo: beneficiario.PermiteEmprestimo,\n        uf: beneficiario.UF,\n        ufBeneficio: beneficiario.UFBeneficio,\n        endereco: beneficiario.Endereco,\n        bairro: beneficiario.Bairro,\n        cidade: beneficiario.Cidade,\n        cep: beneficiario.CEP,\n        \n        // ResumoFinanceiro\n        valorBeneficio: resumoFinanceiro.ValorBeneficio,\n        baseCalculo: resumoFinanceiro.BaseCalculo,\n        margemDisponivelEmprestimo: resumoFinanceiro.MargemDisponivelEmprestimo,\n        margemDisponivelRmc: resumoFinanceiro.MargemDisponivelRmc,\n        margemDisponivelRcc: resumoFinanceiro.MargemDisponivelRcc,\n        totalEmprestimos: resumoFinanceiro.TotalEmprestimos,\n        totalParcelas: resumoFinanceiro.TotalParcelas,\n        totalContrato: resumoFinanceiro.TotalContrato,\n        possuiCartao: resumoFinanceiro.PossuiCartao,\n        descontoAssociacao: resumoFinanceiro.DescontoAssociacao,\n        \n        // DadosBancarios\n        agenciaPagto: dadosBancarios.AgenciaPagto,\n        agencia: dadosBancarios.Agencia,\n        banco: dadosBancarios.Banco,\n        contaPagto: dadosBancarios.ContaPagto,\n        meioPagamento: dadosBancarios.MeioPagamento,\n        \n        // Outros campos\n        dadosRepresentante: entry.DadosRepresentante || [], // Pode estar vazio\n        rmc: entry.Rmc || [], // Pode estar vazio\n        rcc: entry.RCC || [], // Pode estar vazio\n        associacao: entry.Associacao || [], // Pode estar vazio\n        pdfBase64: entry.PdfBase64 // Pode ser null\n      };\n\n      // Adicionando o objeto extraído ao array de resultados\n      result.push(extractedData);\n    }\n  } else {\n    console.log('Erro: data não é um array', data);\n  }\n}\n\n// Retornando todos os dados extraídos\nreturn result.map(item => ({\n  json: item\n}));\n"
      },
