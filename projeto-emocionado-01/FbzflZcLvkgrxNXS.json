    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT COALESCE(MAX(clt_codigo), 0) AS max_clt_codigo\nFROM agilus;\n",
        "options": {}
      },
      "id": "60d9b07a-7028-4124-90ac-4463d09959a3",
      "name": "GetMaxId",
      "type": "n8n-nodes-base.mySql",
      "typeVersion": 2.4,
      "position": [
        -880,
        -220
      ],
      "credentials": {
        "mySql": {
