    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "WITH CTE_UniqueCPFs AS (\nSELECT TOP {{ $('Scheduler').first().json.size }}\n        clt_codigo,\n        clt_cpf,\n        clt_matricula,\n        clt_especie,\n        clt_nome,\n        ROW_NUMBER() OVER (PARTITION BY clt_cpf ORDER BY clt_codigo) AS RowNum\n    FROM \n      dbo.cliente_televenda\n   WHERE\n   \tclt_cpf IS NOT NULL AND\n   \tclt_codigo >= {{ $('GetMaxId').first().json.max_clt_codigo }}\n  ORDER BY\n    clt_codigo ASC\n)\nSELECT *\nFROM CTE_UniqueCPFs\nWHERE RowNum = 1;"
      },
      "id": "5a6f6739-e2b4-4456-a28a-4c63a26971cc",
      "name": "Agilus",
      "type": "n8n-nodes-base.microsoftSql",
      "typeVersion": 1.1,
      "position": [
        -680,
        -220
      ],
      "credentials": {
        "microsoftSql": {
          "id": "Eck1dwqEQjiv5hCV",
          "name": "dboAgilus"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const completeData = $('Agilus').all();\n\nfunction keepOnlyLettersAndSpaces(input) {\n    if (!input) {\n        return \"\"; \n    }\n    return input.replace(/[^a-zA-Z\\s]/g, \"\");\n}\n\nfunction keepOnlyLettersAndNumbers(input) {\n    if (!input) {\n        return \"\"; // Retorna string vazia se for nulo ou vazio\n    }\n    return input.replace(/[^a-zA-Z0-9]/g, \"\"); // Remove tudo que não for letra ou número\n}\n\nfunction cleanString(input) {\n    if (!input) {\n        return \"\"; // Retorna string vazia se for nulo ou vazio\n    }\n    return input.replace(/[.,\\-\\s]/g, \"\"); // Remove ponto, traço, vírgula e espaço\n}\n\nconst normatized = completeData.map((data) => {\n  return {\n    \"clf_cpf\" : data.json.clt_cpf.trim(),\n    \"clt_codigo\" : data.json.clt_codigo,\n    \"clt_matricula\" : data.json.clt_matricula ? keepOnlyLettersAndNumbers(data.json.clt_matricula.trim()) : \"\",\n    \"clt_especie\" : data.json.clt_especie ? keepOnlyLettersAndNumbers(data.json.clt_especie): \"\",\n    \"clt_nome\" : data.json.clt_nome ? keepOnlyLettersAndSpaces(data.json.clt_nome.trim()) : \"\",\n  }\n})\n\nreturn {normatized};"
      },
      "id": "879eb7e9-6a13-4724-9337-5464ec9d1b76",
      "name": "Normatize agilus",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        220,
        -240
      ]
    },
    {
      "parameters": {
        "jsCode": "const data = $('Normatize agilus').first().json.normatized;\n\nfunction nuuabled(item) {\n  if (!item) {\n    return \"NULL\"; \n  }\n  \n  if (typeof(item) == \"string\") {\n      if (item != \"\") {\n          return `'${item}'`;\n      }\n      return \"NULL\";\n  }\n\n  if (typeof(item) == \"undefined\") {\n      return \"NULL\";\n  }\n  return item;\n}\n\n\n\nconst result = data.map(obj => {\n  const values = Object.values(obj).map((value) => nuuabled(value));\n  return `(${values.join(', ')})`;\n}).join(', ');\n\nreturn {result};"
      },
