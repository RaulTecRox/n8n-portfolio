    {
      "parameters": {
        "jsCode": "// Recebendo os dados do nó que contém as informações dos funcionários\nconst dados = items.map(item => item.json);\n\n// Função para determinar a saudação conforme o horário\nconst getSaudacao = () => {\n    const horaAtual = new Date().getHours();\n    if (horaAtual < 12) {\n        return \"Bom dia!\";\n    } else if (horaAtual < 18) {\n        return \"Boa tarde!\";\n    } else {\n        return \"Boa noite!\";\n    }\n};\n\n// Obtém a saudação\nconst saudacao = getSaudacao();\n\n// Inicializa a string HTML da mensagem\nlet html = `\n<p>Prezados, ${saudacao},</p>\n<p>Segue em anexo a lista de usuários de sistemas da empresa atualizada até a data de hoje. A lista contém as informações necessárias de cada usuário, incluindo nome completo, CPF, cargo, e-mail.</p>\n<p>Caso necessitem de alguma informação adicional ou ajuste específico, estamos à disposição para colaborar.</p>\n<p>Atenciosamente,</p>\n<img src=\"https://drive.google.com/uc?id=1xhzjxM9bS0a612t02csjuvSLMEs22fPg\" alt=\"Assinatura\" style=\"max-width: 50%; height: auto;\"><br>`;\n\n// Retorna a mensagem como um resultado\nreturn [{ json: { html } }];\n"
      },
