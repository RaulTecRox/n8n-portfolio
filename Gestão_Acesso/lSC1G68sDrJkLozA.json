    {
      "parameters": {
        "jsCode": "// Acessa todos os dados do nó 'Webhook'\nconst webhookData = $('Webhook').all();\n\n// Verifica se webhookData está definido e é uma array\nif (Array.isArray(webhookData) && webhookData.length > 0) {\n    // Formata os dados no formato desejado para cada item do webhookData\n    const formattedData = webhookData.flatMap(dataItem => {\n        const dados = dataItem.json.body.DADOS || [];\n        \n        return dados.map(item => ({\n            json: {\n                NOME: item.NOME,\n                ID: item.ID,\n                MODELO: item.MODELO,\n                FABRICANTE: item.FABRICANTE,\n                LOCAL: item.LOCAL\n            }\n        }));\n    });\n\n    // Retorna todos os dados formatados\n    return formattedData;\n} else {\n    throw new Error('Dados do webhook não encontrados ou inválidos.');\n}\n"
      },
