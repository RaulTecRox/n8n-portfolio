      {
        "parameters": {
          "command": "=Import-Module ActiveDirectory;\n\n$usuario = \"{{ $json['E-MAIL/USUARIO'] }}\";\n$nome    = \"{{ $json.NOME }}\";\n\n$ouDestino = \"OU=DESLIGAMENTOS,DC=colaborador,DC=local\";\n\n# Grupos que nunca devem ser removidos\n$gruposFixos = @(\"Domain Users\");\n\n$user = Get-ADUser -Filter \"SamAccountName -eq '$usuario'\" `\n    -Properties DistinguishedName, Enabled `\n    -ErrorAction SilentlyContinue;\n\nif (-not $user) {\n    Write-Output \"USUARIO_NAO_ENCONTRADO: $usuario\";\n    exit 0;\n}\n\n# =========================\n# REMOVER GRUPOS\n# =========================\n$gruposRemovidos = @();\n\n$gruposAtuais = Get-ADPrincipalGroupMembership $usuario |\n    Where-Object { $_.Name -notin $gruposFixos } |\n    Select-Object -ExpandProperty SamAccountName;\n\nforeach ($grupo in $gruposAtuais) {\n    try {\n        Remove-ADGroupMember `\n            -Identity $grupo `\n            -Members $usuario `\n            -Confirm:$false;\n        $gruposRemovidos += $grupo;\n    }\n    catch {\n        Write-Output \"ERRO_REMOVER_GRUPO: $grupo\";\n    }\n}\n\n# =========================\n# MOVER PARA OU DESLIGAMENTOS\n# =========================\nif ($user.DistinguishedName -notlike \"*$ouDestino*\") {\n    Move-ADObject `\n        -Identity $user.DistinguishedName `\n        -TargetPath $ouDestino;\n    $ouStatus = \"OU_MOVIDA\";\n}\nelse {\n    $ouStatus = \"OU_JA_DESLIGAMENTOS\";\n}\n\n# =========================\n# DESABILITAR CONTA\n# =========================\nif ($user.Enabled) {\n    Disable-ADAccount -Identity $user;\n    $statusConta = \"CONTA_DESABILITADA\";\n}\nelse {\n    $statusConta = \"CONTA_JA_DESABILITADA\";\n}\n\nWrite-Output \"OK | $usuario | $nome | $ouStatus | $statusConta | GRUPOS_REMOVIDOS: $($gruposRemovidos -join ', ')\";\n",
          "cwd": "C:\\n8n"
        },
