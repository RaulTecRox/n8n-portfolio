      "parameters": {
        "jsCode": "const payloads = items[0].json.data.document.historical_documents.payload;\n\nconst benefícios = payloads.map((beneficioArray, index) => {\n  const beneficioObj = {};\n\n  beneficioArray.forEach(campo => {\n    beneficioObj[campo.title] = campo.value;\n  });\n\n  return {\n    json: {\n      beneficio_index: index + 1,\n      ...beneficioObj\n    }\n  };\n});\n\nreturn benefícios;\n"
      },
