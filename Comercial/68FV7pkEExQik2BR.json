      "onError": "continueErrorOutput"
    },
    {
      "parameters": {
        "jsCode": "const data = items[0].json.data;\nconst resultado = [];\n\nconst getIdade = (nasc) => {\n  const [dia, mes, ano] = nasc.split('/');\n  const nascimento = new Date(`${ano}-${mes}-${dia}`);\n  const hoje = new Date();\n  let idade = hoje.getFullYear() - nascimento.getFullYear();\n  const m = hoje.getMonth() - nascimento.getMonth();\n  if (m < 0 || (m === 0 && hoje.getDate() < nascimento.getDate())) {\n    idade--;\n  }\n  return idade.toString();\n};\n\n// Filtrar contatos com WhatsApp = SIM\nconst contatosComWhatsApp = data.filter(d => d.WHATSAPP === \"SIM\");\n\nif (contatosComWhatsApp.length > 0) {\n  const pessoa = contatosComWhatsApp[0]; // pega o primeiro com WhatsApp SIM\n  const cpf = pessoa.CPFCNPJ;\n  const nome = pessoa.NOME;\n  const idade = getIdade(pessoa.NASC);\n  \n  // Pega até 2 telefones\n  const telefones = contatosComWhatsApp.map(d => d.TELEFONE);\n  const telefone_1 = telefones[0] || \"\";\n  const telefone_2 = telefones[1] || \"\";\n\n  resultado.push({\n    json: {\n      CPF: cpf,\n      NOME: nome,\n      IDADE: idade,\n      TELEFONE_1: telefone_1,\n      TELEFONE_2: telefone_2\n    }\n  });\n}\n\nreturn resultado;\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        3660,
        180
      ],
