      "parameters": {
        "jsCode": "// Recebe os dados do campo \"Edit Fields\" do JSON\nconst data = $('Edit Fields Instacias').all();  // Acessa o campo \"Edit Fields\" diretamente\n\n// Função para selecionar um item aleatório do array\nconst getRandomItem = (array) => {\n  const randomIndex = Math.floor(Math.random() * array.length);  // Gera um índice aleatório\n  return array[randomIndex];  // Retorna o item aleatório\n};\n\n// Retorna o item aleatório\nreturn getRandomItem(data);\n"
