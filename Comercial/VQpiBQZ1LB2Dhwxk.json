    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst groupedData = {};\n\n// Agrupa os registros por CPF e armazena os telefones em uma lista\nitems.forEach(item => {\n    const { CPF, NOME, TELEFONE } = item.json;\n\n    if (!groupedData[CPF]) {\n        groupedData[CPF] = { CPF, NOME, TELEFONES: new Set() };\n    }\n\n    // Adiciona os telefones em um Set para evitar duplicatas\n    groupedData[CPF].TELEFONES.add(TELEFONE);\n});\n\n// Converte para o formato de saída esperado\nconst output = Object.values(groupedData).map(({ CPF, NOME, TELEFONES }) => {\n    const result = { CPF, NOME };\n    \n    // Converte o Set para Array e garante que tenha 4 telefones, preenchendo com null se necessário\n    const telefoneArray = Array.from(TELEFONES);\n    while (telefoneArray.length < 4) {\n        telefoneArray.push(null);\n    }\n\n    // Adiciona os telefones como TELEFONE 1, TELEFONE 2, ..., TELEFONE 4\n    telefoneArray.forEach((tel, index) => {\n        result[`TELEFONE ${index + 1}`] = tel;\n    });\n\n    return { json: result };\n});\n\nreturn output;\n"
      },
