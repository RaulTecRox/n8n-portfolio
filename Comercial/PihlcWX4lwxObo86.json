    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT\n\t*\nFROM\n\targus_tabs\nWHERE\n\tidTabulacao = {{ $('Loop Over Tabs').first().json.tabs }} AND\n\tidGrupoUsuario = {{ $('Loop Over userGroups').first().json.userGroups }} AND\n\tDATE(dataEvento) = '{{ $('Settings').first().json.dateToSearch }}' AND\n    nomeCliente IS NOT NULL\n    LIMIT 100;",
        "options": {}
      },
      "id": "41feb1e3-c64e-428e-906c-4e05d4277dd3",
      "name": "Getting data",
      "type": "n8n-nodes-base.mySql",
      "typeVersion": 2.4,
      "position": [
        1720,
        -380
      ],
      "alwaysOutputData": true,
      "credentials": {
        "mySql": {
          "id": "McVpZOscKHG1eIW2",
          "name": "Tabuargulus"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const blockSize = $('Settings').first().json.blockSize;\nconst calls = $('Getting data').all();\nconst quantity = calls.length;\nconst blocks = Math.ceil(quantity / blockSize);\nconst createdBy = \"rpa\";\nconst sendBy = '[\\\"SMS\\\"]';\n\nlet result = [];\n\nfunction getFirstAndLastWords(str) {\n  if (str) {\n    const words = str.trim().split(/\\s+/);\n      if (words.length === 0) {\n        return { firstWord: \"\", lastWord: \"\" };\n      }\n    const firstWord = words[0];\n    const lastWord = words[words.length - 1];\n    \n    return { firstWord, lastWord };\n  } else {\n    return { firstWord: \"\", lastWord: \"\" };\n  }\n}\n\nfor (let i = 0; i < blocks; i++) {\n  \n  const start = i * blockSize;\n  const end = start + blockSize;\n  const block = calls.slice(start, end);\n  \n  const insertString = block.map((item) => {\n    const name = getFirstAndLastWords(item.json.nomeCliente);\n    \n      return `(` +\n      `${ item.json.idGrupoUsuario},` +\n      `'${ item.json.telefone}',` +\n      `'${ name.firstWord }',` +\n      `'${ name.lastWord }',` +\n      `'${ createdBy }',` +\n      `'${ sendBy }',` +\n      `CURRENT_TIMESTAMP()` +\n      `)`;\n  }).join(',');\n\n  result.push(insertString);\n}\n\nreturn {result};"
      },
