    {
      "parameters": {
        "jsCode": "const dateToSearch = getPreviousDate()\nconst timeToWait = 1;\n\nconst userGroups = [9,]; // Empresas filiais\n\nconst tabs = [10, 15, 16, 17]; // ids das tabulações\n\nconst blockSize = 1000; // Tamanho da paginação de insert em massa\n\nfunction getPreviousDate() {\n  const now = new Date();\n  const offset = -3;\n  const saoPauloTime = new Date(now.getTime() + (offset * 60 - now.getTimezoneOffset()) * 60000);\n\n  saoPauloTime.setDate(saoPauloTime.getDate() - 1);\n\n  const formattedDate = saoPauloTime.toISOString().slice(0, 10);\n\n  return formattedDate;\n}\n\nreturn {dateToSearch, timeToWait, blockSize, userGroups, tabs }"
      },
