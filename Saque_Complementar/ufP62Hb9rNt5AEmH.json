      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT \n\tMIN(af.Af_codigo) AS Af_codigo, -- Ou outro critério para pegar um registro único\n\tMIN(af.Af_data) AS Af_data, \n\taf.Bcolib_codigo, \n\tMIN(bancolib.Bcolib_descricao) AS Bcolib_descricao, \n\tconvenio.Con_cpf\nFROM dbo.af AS af\nINNER JOIN dbo.convenio AS convenio ON af.Con_codigo = convenio.Con_codigo\nINNER JOIN dbo.bancolib AS bancolib ON af.Bcolib_codigo = bancolib.Bcolib_codigo\nWHERE af.Af_data BETWEEN '2025-01-01 00:00:00.000' AND '2025-12-31 00:00:00.000'\nAND af.Bcolib_codigo = 318\nGROUP BY convenio.Con_cpf, af.Bcolib_codigo;\n"
