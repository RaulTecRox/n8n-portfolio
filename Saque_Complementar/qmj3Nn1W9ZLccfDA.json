    {
      "parameters": {
        "jsCode": "let rawBody = $input.first().json.body;\n\n// Etapa 1: Remover quebras de linha reais e espaços extras\nrawBody = rawBody.replace(/[\\n\\r]/g, '').trim();\n\n// Etapa 2: Corrigir campos faltando (exemplo: \"banco_codigo\": , → \"banco_codigo\": null)\nrawBody = rawBody.replace(/\"banco_codigo\":\\s*,/, '\"banco_codigo\": null,');\n\n// Etapa 3: Fazer o parse\nlet parsedBody;\n\ntry {\n  parsedBody = JSON.parse(rawBody);\n} catch (error) {\n  throw new Error(\"Erro ao fazer o parse do JSON: \" + error.message);\n}\n\nreturn parsedBody;\n"
      },
