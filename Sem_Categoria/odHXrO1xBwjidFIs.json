    {
      "parameters": {
        "operation": "executeQuery",
        "query": "DECLARE @nomeBanco VARCHAR(100) = '{{ $json.nomeBanco }}';  -- '' ou NULL = não filtra\nDECLARE @codigoBanco INT = {{ $json.codigoBanco }};           -- se vier 0, tratar como sem filtro\n\nSELECT  \n    af.af_codigo,\n    af.Af_codigo_contrato_banco,\n    af.Bcolib_codigo,\n    ban.bcolib_descricao,\n    af.faf_codigo,\n    fase.faf_descricao\nFROM dbo.af af\nLEFT JOIN dbo.bancolib ban ON af.Bcolib_codigo = ban.Bcolib_codigo\nLEFT JOIN dbo.fase_af fase ON af.faf_codigo = fase.faf_codigo\nWHERE \n    af.faf_codigo IN (2, 10, 60, 93)\n\n    -- filtro opcional por nome\n    AND (\n            @nomeBanco IS NULL\n            OR @nomeBanco = ''\n            OR ban.bcolib_descricao LIKE '%' + @nomeBanco + '%'\n        )\n\n    -- filtro opcional por código (0 = sem filtro)\n    AND (\n            @codigoBanco IS NULL\n            OR @codigoBanco = 0\n            OR af.Bcolib_codigo = @codigoBanco\n        )\n\nORDER BY af.af_codigo;\n"
      },
      "type": "n8n-nodes-base.microsoftSql",
      "typeVersion": 1.1,
      "position": [
