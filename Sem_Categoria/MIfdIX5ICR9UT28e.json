    {
      "parameters": {
        "jsCode": "const parsed = JSON.parse($json.stdout);\n\n// Garante que sempre seja array\nconst files = Array.isArray(parsed) ? parsed : [parsed];\n\n// Converte data do formato /Date(1769467597272)/\nfunction parseDotNetDate(dateString) {\n  const match = dateString.match(/\\/Date\\((\\d+)\\)\\//);\n  return match ? new Date(Number(match[1])).toISOString() : null;\n}\n\nreturn files.map(file => {\n  return {\n    json: {\n      fileName: file.Name,\n      remotePath: file.FullName.replace(/\\\\/g, '/'),\n      size: file.Length,\n      lastWriteTime: parseDotNetDate(file.LastWriteTime)\n    }\n  };\n});\n"
      },
