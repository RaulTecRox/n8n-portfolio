    {
      "parameters": {
        "jsCode": "return items.filter(item => {\n  const dados = item.json;\n  \n  // 1. Limpeza do valor padrão BR (Ex: \"96.996,55\")\n  // .replace(/\\./g, '') -> Remove todos os pontos de milhar (vira \"96996,55\")\n  // .replace(',', '.')  -> Troca a vírgula por ponto (vira \"96996.55\")\n  const valorTexto = dados['VALOR SOLICITADO'] || \"0\";\n  const valorLimpo = valorTexto.toString().replace(/\\./g, '').replace(',', '.');\n  const valor = parseFloat(valorLimpo);\n\n  const tipo = dados['TIPO'];\n\n  // 2. Lógica RPV: Entre 20k e 60k\n  if (tipo === 'RPV' && valor >= 20000 && valor <= 60000) {\n    return true;\n  }\n\n  // 3. Lógica PRC: Acima ou igual a 50k\n  if (tipo === 'PRC' && valor >= 50000) {\n    return true;\n  }\n\n  return false;\n});"
      },
