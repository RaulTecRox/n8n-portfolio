    {
      "parameters": {
        "jsCode": "const data = items[0].json;\n\nif (!data.SerializedObject) return items;\n\nconst parsed = JSON.parse(data.SerializedObject);\n\n// Pega o primeiro item do array\nconst proposta = parsed.PropostaProdutoDisponivel?.[0] || {};\n\nreturn [\n  {\n    json: {\n      IsResponseOk: data.IsResponseOk,\n      StatusCode: data.StatusCode,\n      ...proposta\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
