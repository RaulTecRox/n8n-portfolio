      "id": "c1c32b20-d054-486f-82fa-92170de7f34d",
      "name": "Code in JavaScript2"
    },
    {
      "parameters": {
        "jsCode": "// Captura o primeiro item da entrada\nconst input = items[0].json;\n\n// 1. Transforma a string do SerializedObject em um objeto JSON real\nconst serializedData = JSON.parse(input.SerializedObject);\n\n// 2. Extrai a lista de parâmetros\nconst listaParametros = serializedData.ListaParametros;\n\n// 3. Retorna a lista mapeada para o formato do n8n\n// Isso fará com que cada parâmetro vire um \"item\" individual no fluxo\nreturn listaParametros.map(parametro => {\n  return {\n    json: parametro\n  };\n});"
      },
