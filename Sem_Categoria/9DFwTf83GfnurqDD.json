    {
      "parameters": {
        "operation": "executeQuery",
        "query": "START TRANSACTION;\n\n-- Pega o último id com step = 'SUCCESS'\nSELECT id\nINTO @last_id\nFROM consulted\nWHERE step = 'SUCCESS'\nORDER BY id DESC\nLIMIT 1;\n\n-- Atualiza todos os registros anteriores\nUPDATE consulted\nSET step = 'EXPORTING'\nWHERE step = 'SUCCESS'\n  AND id <= @last_id;\n\n-- Retorna os registros que acabaram de ser exportados\nSELECT payload\nFROM consulted\nWHERE step = 'EXPORTING'\n  AND id < @last_id;\n\nCOMMIT;",
        "options": {}
      },
