        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "{\n  \"size\": 100,\n  \"_source\": [\n    \"numeroProcesso\",\n    \"valorCausa\",\n    \"partes.nome\",\n    \"partes.polo\",\n    \"dataHoraUltimaAtualizacao\"\n  ],\n  \"query\": {\n    \"bool\": {\n      \"must\": [\n        {\n          \"query_string\": {\n            \"query\": \"(RPV OR \\\"Requisição de Pequeno Valor\\\" OR Precatório OR PRC)\",\n            \"default_field\": \"movimentos.nome\"\n          }\n        }\n      ],\n      \"must_not\": [\n        {\n          \"query_string\": {\n            \"query\": \"(Pago OR Pagamento OR Depósito OR Levantamento OR Quitado OR Baixa)\",\n            \"default_field\": \"movimentos.nome\"\n          }\n        }\n      ],\n      \"filter\": [\n        {\n          \"term\": { \"nivelSigilo\": 0 }\n        }\n      ]\n    }\n  },\n  \"sort\": [\n    {\n      \"dataHoraUltimaAtualizacao\": {\n        \"order\": \"desc\"\n      }\n    }\n  ]\n}\n",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        208,
