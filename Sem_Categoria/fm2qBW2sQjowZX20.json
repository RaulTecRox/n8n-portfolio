        624,
        0
      ],
      "id": "56ecf94e-91cc-4119-a19b-b01c201a1376",
      "name": "Limit"
    },
    {
      "parameters": {
        "url": "https://api-publica.datajud.cnj.jus.br/api_publica_trf3/_search",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "APIKey cDZHYzlZa0JadVREZDJCendQbXY6SkJlTzNjLV9TRENyQk1RdnFKZGRQdw=="
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n    \"query\": {\n        \"match\": {\n          \"numeroProcesso\":\" {{ $json.numeroProcesso }}\"\n        }\n    }\n}",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        480,
        304
      ],
      "id": "254b53c9-9aae-421c-81c2-c6863efd0e86",
      "name": "HTTP Request2"
    },
    {
      "parameters": {
        "jsCode": "const resultado = [];\n\nfor (const item of items) {\n\n  const listaHits = item.json?.hits?.hits || [];\n\n  for (const processo of listaHits) {\n\n    const source = processo._source;\n    if (!source) continue;\n\n    const movimentos = source.movimentos || [];\n\n    const temRPV = movimentos.some(m =>\n      m.nome?.toLowerCase().includes(\"rpv\") ||\n      m.nome?.toLowerCase().includes(\"precatório\")\n    );\n\n    const temPagamento = movimentos.some(m =>\n      m.nome?.toLowerCase().includes(\"pago\") ||\n      m.nome?.toLowerCase().includes(\"pagamento\") ||\n      m.nome?.toLowerCase().includes(\"depósito\") ||\n      m.nome?.toLowerCase().includes(\"quitado\") ||\n      m.nome?.toLowerCase().includes(\"levantamento\")\n    );\n\n    resultado.push({\n      json: {\n        numeroProcesso: source.numeroProcesso,\n        orgaoJulgador: source.orgaoJulgador?.nome,\n        ultimaAtualizacao: source.dataHoraUltimaAtualizacao,\n        rpvExpedida: temRPV,\n        pagamentoIdentificado: temPagamento,\n        statusFinanceiro:\n          temRPV && !temPagamento\n            ? \"AGUARDANDO PAGAMENTO\"\n            : temRPV && temPagamento\n            ? \"PAGO\"\n            : \"SEM RPV\"\n      }\n    });\n  }\n}\n\nreturn resultado;\n"
      },
