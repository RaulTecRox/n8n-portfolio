      ],
      "id": "8d1962c8-a1d0-44a3-a5eb-c75f81d77a18",
      "name": "HTTP Request1"
    },
    {
      "parameters": {
        "jsCode": "const response = items[0].json;\n\nif (!response.hits || !response.hits.hits) {\n  return [];\n}\n\nconst processos = response.hits.hits.map(item => {\n  return {\n    json: {\n      tribunal: item._index, // ex: api_publica_trf3\n      idElastic: item._id,   // ex: TRF3_JE_50040331920254036315\n      numeroProcesso: item._source.numeroProcesso,\n      dataUltimaAtualizacao: item._source.dataHoraUltimaAtualizacao\n    }\n  };\n});\n\nreturn processos;\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        416,
        0
      ],
      "id": "13e9fe51-a79f-434d-8afb-0c20054ac551",
      "name": "Code in JavaScript"
    },
