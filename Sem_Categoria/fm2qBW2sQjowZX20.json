      ],
      "id": "420a2c2f-8479-4651-a852-62c9b73e28bb",
      "name": "HTTP Request"
    },
    {
      "parameters": {
        "url": "https://api-publica.datajud.cnj.jus.br/api_publica_trf3/_search",
        "sendHeaders": true,
