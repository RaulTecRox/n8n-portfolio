            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"size\": 1,\n  \"_source\": [\n    \"numeroProcesso\",\n    \"classe.nome\",\n    \"valorCausa\",\n    \"dataAjuizamento\",\n    \"dataHoraUltimaAtualizacao\",\n    \"orgaoJulgador.nome\",\n    \"assuntos.nome\",\n    \"partes.nome\",\n    \"partes.polo\",\n    \"movimentos.nome\",\n    \"movimentos.dataHora\"\n  ],\n  \"query\": {\n    \"term\": {\n      \"numeroProcesso\": \"{{ $json.numeroProcesso }}\"\n    }\n  }\n}\n",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
