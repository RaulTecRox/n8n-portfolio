    {
      "parameters": {
        "jsCode": "// Input: Recebemos os dados como JSON. Vamos criar uma mensagem de texto personalizada.\n// Pegando os dados do nó anterior no n8n.\nconst input = $input.all();\n\n// Mapeamos o JSON para coletar nome e status das instâncias\nconst mensagens = input.map(item => {\n  const instanceName = item.json.instance.instanceName;\n  const status = item.json.instance.status;\n\n  // Criamos uma mensagem personalizada\n  return `A instância \"${instanceName}\" está com o status: \"${status}\".`;\n});\n\n// Juntamos todas as mensagens em um único texto\nconst mensagemFinal = mensagens.join('\\n');\n\n// Retornamos a mensagem no formato necessário para a EvolutionAPI\nreturn {\n  textMessage: {\n    msg: JSON.stringify(mensagemFinal.trim())\n  }\n};\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2000,
        840
      ],
      "id": "fc691e39-5bd9-4e8b-9f84-e3fbac538426",
      "name": "Code"
    },
    {
      "parameters": {
        "jsCode": "// Input: Recebemos os dados como JSON. Vamos criar uma mensagem com o telefone e o nome do cliente, se existir.\n// Pegando os dados do nó anterior no n8n.\nconst input = $input.all();\n\n// Mapeamos o JSON para coletar o telefone e o nome do cliente\nconst mensagens = input.map(item => {\n  const telefone = item.json.body.telefone;\n  const nomeCliente = item.json.body.nomeCliente;\n\n  // Se o nome do cliente estiver presente, incluímos na mensagem\n  if (nomeCliente) {\n    return `Recebemos um aceite da URA do cliente ${nomeCliente} telefone ${telefone}.`;\n  } else {\n    return `Recebemos um aceite da URA do telefone ${telefone}.`;\n  }\n});\n\n// Juntamos todas as mensagens em um único texto\nconst mensagemFinal = mensagens.join('\\n');\n\n// Retornamos a mensagem no formato necessário para a EvolutionAPI\nreturn {\n  textMessage: {\n    msg: JSON.stringify(mensagemFinal.trim())\n  }\n};\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        640,
        1140
      ],
