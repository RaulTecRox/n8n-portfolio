      "parameters": {
        "jsCode": "// Garante que há conteúdo vindo do node anterior\nconst input = $input.item.json;\n\nconst html = input.body || input.data || \"\"; // tenta pegar o campo certo\n\n// Expressão regular simples para achar trechos com a palavra \"precatório\"\nconst matches = html.match(/[^>]{0,100}precat[óo]rio[^<]{0,100}/gi) || [];\n\nreturn matches.map(trecho => {\n  return {\n    json: {\n      trecho: trecho.trim()\n    }\n  };\n});\n"
