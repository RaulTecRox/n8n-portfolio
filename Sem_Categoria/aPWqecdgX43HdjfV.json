    {
      "parameters": {
        "jsCode": "// Input data (from the previous node)\nconst jsonData = $json;\n\n// Extract the required fields from each item\nconst filteredData = jsonData.hits.hits.map(item => {\n  const source = item._source;\n  return {\n    numeroProcesso: source.numeroProcesso,\n    tribunal: source.tribunal,\n    dataHoraUltimaAtualizacao: source.dataHoraUltimaAtualizacao,\n    dataAjuizamento: source.dataAjuizamento,\n    nome: source.classe.nome // Alteração aqui: Usando classe.nome em vez de orgaoJulgador.nome\n  };\n});\n\n// Return the filtered data\nreturn filteredData;"
      },
