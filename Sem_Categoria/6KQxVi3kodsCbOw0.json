    {
      "parameters": {
        "jsCode": "const encodex = $('Count encodex').all();\n\nconst completeBaseError =\n  encodex.find(\n    item =>\n      item.json.origem === 'complete_base' &&\n      item.json.step === 'ERROR'\n  )?.json?.total ?? 0;\n\nconst completeBaseSuccess =\n  encodex.find(\n    item =>\n      item.json.origem === 'complete_base' &&\n      item.json.step === 'SUCCESS'\n  )?.json?.total ?? 0;\n\nconst consultedSuccess =\n  encodex.find(\n    item =>\n      item.json.origem === 'consulted' &&\n      item.json.step === 'SUCCESS'\n  )?.json?.total ?? 0;\n\nconst consultedError =\n  encodex.find(\n    item =>\n      item.json.origem === 'consulted' &&\n      item.json.step === 'ERROR'\n  )?.json?.total ?? 0;\n\nreturn {\n  completeBaseError,\n  completeBaseSuccess,\n  consultedSuccess,\n  consultedError\n};\n"
      },
