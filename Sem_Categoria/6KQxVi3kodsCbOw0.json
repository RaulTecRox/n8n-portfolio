    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT\n    'consulted' AS origem,\n    step,\n    COUNT(*) AS total\nFROM consulted\nWHERE \n    DATE(consulted_at) = CURDATE()\n    AND step IN ('SUCCESS', 'ERROR')\nGROUP BY step\n\nUNION ALL\n\nSELECT\n    'complete_base' AS origem,\n    step,\n    COUNT(*) AS total\nFROM complete_base\nWHERE \n    DATE(updated_at) = CURDATE()\n    AND step IN ('SUCCESS', 'ERROR')\nGROUP BY step\n\nORDER BY origem, step;\n",
        "options": {}
      },
