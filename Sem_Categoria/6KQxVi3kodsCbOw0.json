;color:#ffffff;font-size:12px;font-weight:bold;\">\n                    CODIFICADOS ERRO\n                </span>\n            </td>\n            <td style=\"padding:14px;text-align:center;font-size:16px;font-weight:bold;color:#1e88e5;\">\n                {{ $json.consultedError }}\n            </td>\n        </tr>\n\n        <tr style=\"background-color:#f7fbfa;\">\n            <td style=\"padding:14px;text-align:center;\">\n                <span\n                    style=\"display:inline-block;padding:6px 14px;border-radius:20px;background-color:#0f9d58;color:#ffffff;font-size:12px;font-weight:bold;\">\n                    CLIENTES ENCONTRADOS\n                </span>\n            </td>\n            <td style=\"padding:14px;text-align:center;font-size:16px;font-weight:bold;color:#1e88e5;\">\n                {{ $json.completeBaseSuccess }}\n            </td>\n        </tr>\n\n        <tr style=\"background-color:#ffffff;\">\n            <td style=\"padding:14px;text-align:center;\">\n                <span\n                    style=\"display:inline-block;padding:6px 14px;border-radius:20px;background-color:#e53935;color:#ffffff;font-size:12px;font-weight:bold;\">\n                    CLIENTES NÃO LOCALIZADOS\n                </span>\n            </td>\n            <td style=\"padding:14px;text-align:center;font-size:16px;font-weight:bold;color:#1e88e5;\">\n                {{ $json.completeBaseError }}\n            </td>\n        </tr>\n    </tbody>\n\n</table>\n\n<p style=\"max-width:700px;margin:10px auto 0 auto;padding:12px 16px;\nfont-family:Arial,Helvetica,sans-serif;font-size:13px;color:#555;\nbackground-color:#f1f8f6;border-left:4px solid #0f9d58;border-radius:6px;\">\n    <strong>Observação:</strong> Os valores apresentados podem sofrer variações até o fechamento do dia\n    (00h), uma vez que se tratam de uma <strong>contagem parcial</strong> dos dados coletados\n    em suas respectivas plataformas no momento da extração.\n</p>\n\n\n</br>\n\n<p style=\"font-family: Arial, sans-serif; font-size: 16px; color: #555;\">Atenciosamente,</p>\n\n<table cellpadding=\"0\" cellspacing=\"0\" style=\"font-family:Arial,Helvetica,sans-serif;max-width:500px;\">\n    <tr>\n        <td style=\"padding-right:16px;vertical-align:top;\">\n            <!-- Ícone / Logo -->\n            <div\n                style=\"width:64px;height:64px;border-radius:50%;background:linear-gradient(135deg,#0f9d58,#1e88e5);display:flex;align-items:center;justify-content:center;color:#ffffff;font-size:24px;font-weight:bold;\">\n                MDG\n            </div>\n        </td>\n\n        <td style=\"vertical-align:top;\">\n            <!-- Nome -->\n            <div style=\"font-size:16px;font-weight:bold;color:#1e88e5;line-height:1.2;\">\n                Anderson Tome\n            </div>\n\n            <!-- Empresa -->\n            <div style=\"font-size:13px;font-weight:bold;color:#0f9d58;\">\n                MDG Intermediações\n            </div>\n\n            <!-- Linha -->\n            <div style=\"height:1px;background-color:#e0e0e0;margin:8px 0;\"></div>\n\n            <!-- Contatos -->\n            <div style=\"font-size:12px;color:#333333;line-height:1.6;\">\n                📧 <a href=\"mailto:anderson.tome@mdgintermediacoes.com.br\" style=\"color:#1e88e5;text-decoration:none;\">\n                    anderson.tome@mdgintermediacoes.com.br\n                </a><br>\n\n                📧 <a href=\"mailto:desenvolvimento@mdgintermediacoes.com.br\"\n                    style=\"color:#1e88e5;text-decoration:none;\">\n                    desenvolvimento@mdgintermediacoes.com.br\n                </a><br>\n\n                📞 <a href=\"tel:+5519981746254\" style=\"color:#1e88e5;text-decoration:none;\">\n                    +55 (19) 98174-6254\n                </a><br>\n\n                🌐 <a href=\"https://www.mdgintermediacoes.com.br\" style=\"color:#1e88e5;text-decoration:none;\">\n                    www.mdgintermediacoes.com.br\n                </