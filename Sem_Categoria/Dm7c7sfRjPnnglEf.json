    {
      "parameters": {
        "jsCode": "const lines = $input.first().json.text.split(\"\\n\");\nconst items = [];\n\nfor (let line of lines) {\n    // Regex corrigida para aceitar letras minúsculas, R$ no final e valores zerados/com hífen\n    const match = line.match(/^(.+?)\\s+([a-zA-Z0-9]+)\\s+([a-zA-Z0-9]+)\\s+([a-zA-Z0-9\\/]+)\\s+([\\d,.-]+)R\\$/);\n    \n    if (match) {\n        items.push({\n            produto: match[1].trim(),\n            codigo_barras: match[2].trim(),\n            patrimonio: match[3].trim(),\n            lote: match[4].trim(),\n            valor: match[5].trim()\n        });\n    }\n}\n\nreturn items.map(item => ({ json: item }));"
      },
