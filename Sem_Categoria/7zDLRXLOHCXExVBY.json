  "nodes": [
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT \n    a.Af_codigo AS codigoAf,\n    a.Af_valor_af AS valorAf,\n    a.Af_valor_comissao_empresa,\n    a.Af_bonus_empresa,\n\n    a.fil_codigo,\n    f.fil_descricao AS Filial,\n    \n    o.Orgav_codigo,\n    o.Orgav_descricao AS orgao\n\nFROM dbo.af a\nJOIN dbo.representante r ON a.Rep_codigo = r.Rep_codigo\nJOIN dbo.representante r2 ON r.Rep_superior = r2.Rep_codigo\nJOIN dbo.convenio c ON a.Con_codigo = c.Con_codigo\nJOIN dbo.filial f ON a.fil_codigo = f.fil_codigo\nJOIN dbo.produto p ON a.prd_codigo = p.prd_codigo\nJOIN dbo.orgaoav o ON p.Orgav_codigo = o.Orgav_codigo\n\nWHERE \n    CAST(a.Af_data AS DATE) = CAST(DATEADD(DAY, -0, GETDATE()) AS DATE)\n    AND a.faf_codigo IN (2, 3, 10, 58, 59, 60, 62, 72, 93, 94);\n"
      },
