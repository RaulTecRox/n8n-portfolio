        "jsCode": "const dados = $items();\n\n// Função formatadora\nconst format = (val) => new Intl.NumberFormat('pt-BR', {\n  style: 'currency',\n  currency: 'BRL',\n  minimumFractionDigits: 2\n}).format(val ?? 0);\n\n// Função para agrupar por filial\nfunction agruparPorFilial(lista, campoValor, chaveInterna) {\n  const grupos = {};\n  lista\n    .filter(item => item.json[chaveInterna])\n    .forEach(item => {\n      const obj = item.json[chaveInterna];\n      const filial = obj.fil_descricao || \"❌ Filial não informada\";\n      const valor = obj[campoValor] || 0;\n      if (!grupos[filial]) {\n        grupos[filial] = { filial, valor: 0 };\n      }\n      grupos[filial].valor += valor;\n    });\n  return Object.values(grupos);\n}\n\n// Agrupamentos\nconst inssDetalhado = agruparPorFilial(dados, 'Af_valor_af', 'inss');\nconst prefDetalhado = agruparPorFilial(dados, 'Af_valor_af', 'prefsp');\nconst govDetalhado = agruparPorFilial(dados, 'Af_valor_af', 'govsp');\nconst caldasDetalhado = agruparPorFilial(dados, 'Af_valor_af', 'prefcaldasnovas'); // novo grupo\n\n// Totais gerais\nconst total = dados.find(item => item.json.empresaTotal)?.json.empresaTotal || {};\nconst totalEmpresas = dados\n  .filter(item => item.json.prodEmpresa)\n  .map(item => item.json.prodEmpresa);\n\n// Data atual\nconst dataHoje = new Date().toLocaleDateString('pt-BR');\n\n// Função para montar texto de cada grupo\nfunction montarEmpresa(nome, dados) {\n  let texto = `🏢 ${nome}\\n`;\n  if (dados.length === 0) {\n    texto += `   • Nenhum dado encontrado\\n`;\n    return texto;\n  }\n  dados.forEach(item => {\n    texto += `   • ${item.filial}: ${format(item.valor)}\\n`;\n  });\n  return texto;\n}\n\n// Receita geral formatada linha a linha\nconst receitaGeralTexto = totalEmpresas.map(emp => \n  `🏢 ${emp.fil_descricao || \"❌ Filial não informada\"}\\n` +\n  `📊 Produção Total: ${format(emp.ProducaoTotal)}\\n` +\n  `💰 Receita: ${format(emp.Receita)}\\n` +\n  `📈 Percentual Receita: ${emp.ReceitaEmpresaPorcentTotal}%\\n`\n).join('\\n');\n\n// Mensagem final\nconst mensagem = \n`Boa tarde, HOJE (${dataHoje})\n\nFinalizamos o dia com:\n📊 Produção Total: ${format(total.Producao)}\n💰 Receita: ${format(total.Receita)}\n📈 Percentual Receita: ${(total.PorcentTotal ?? 0).toFixed(2)}%\n\n📌 Detalhamento por empresa:\n\n${montarEmpresa(\"INSS\", inssDetalhado)}\n${montarEmpresa(\"PREF SP\", prefDetalhado)}\n${montarEmpresa(\"GOV SP\", govDetalhado)}\n${montarEmpresa(\"PREF CALDAS NOVAS\", caldasDetalhado)}\n\n🔍 Receita Geral por Filial:\n${receitaGeralTexto}\n`;\n\n// Lista de contatos para disparo\nconst contatos = [\n  { nome: \"Felipe\", numero: \"5519960001690\" },\n  { nome: \"Denis\", numero: \"5519981353889\" },\n  { nome: \"Daniel\", numero: \"5519996109532\" }\n];\n\n// Retorna uma mensagem para cada contato\nreturn contatos.map(contato => ({\n  json: {\n    nome: contato.nome,\n    numero: contato.numero,\n    message: mensagem\n  }\n}));\n"
      },
