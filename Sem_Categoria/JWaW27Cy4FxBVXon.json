      "position": [
        432,
        160
      ],
      "id": "f04e8c22-3194-4dca-9320-fe74562eea5e",
      "name": "Consulta credilus",
      "retryOnFail": true,
      "onError": "continueErrorOutput"
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nlet novaVida = null;\nlet credilink = null;\n\n// identificar origem dos dados\nfor (const item of items) {\n\n  if (item.json?.d?.CONSULTA) {\n    novaVida = item.json.d.CONSULTA;\n  }\n\n  if (item.json?.data) {\n    credilink = item.json.data;\n  }\n\n}\n\nreturn [\n{\njson: {\n\nnovaVidaTI: novaVida ? {\n\ncadastro: novaVida.CADASTRAIS,\n\nenderecos: novaVida.ENDERECOS,\n\ntelefones: novaVida.TELEFONES,\n\nemails: novaVida.EMAILS,\n\nperfil_consumo: novaVida.PERFILCONSUMO,\n\nsociedades: novaVida.SOCIEDADES,\n\npessoas_ligadas: novaVida.PESSOASLIGADAS,\n\nsituacao_cadastral: novaVida.SITUACAOCADASTRAL,\n\npep: novaVida.PEP\n\n} : null,\n\ncredilink: credilink ? credilink.map(c => ({\n\ndados_basicos: {\ncpf: c.CPFCNPJ,\nnome: c.NOME,\nnascimento: c.NASC,\nsexo: c.SEXO,\nmae: c.MAE\n},\n\nendereco: {\nlogradouro: c.ENDERECO,\nnumero: c.NUMERO,\nbairro: c.BAIRRO,\ncidade: c.CIDADE,\nuf: c.UF,\ncep: c.CEP,\ncomplemento: c.COMPLEMENTO\n},\n\ncontato: {\ntelefone: c.TELEFONE,\nwhatsapp: c.WHATSAPP,\noperadora: c.OPERADORA,\nemails: c.EMAILS ? c.EMAILS.split(\",\") : []\n},\n\nempresa: {\ncnpj: c.CNPJEMPRESASOCIO,\nrazao: c.EMPRESASOCIO,\ncidade: c.ENDERCIDADEEMPRESASOCIO,\nbairro: c.ENDERBAIRROEMPRESASOCIO\n},\n\noutros: {\nveiculo: c.VEICULO,\nprocon: c.PROCON,\nstatus_telefone: c.STATUSTELEFONE,\natualizacao: c.ATUALIZACAO\n}\n\n})) : []\n\n}\n}\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        848,
        -16
      ],
