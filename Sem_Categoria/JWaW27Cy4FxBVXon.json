      "parameters": {
        "url": "https://credilus.app.mdgintermediacoes.com.br/api/v1/credilink/search/wsdl/cpf",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "cpf",
              "value": "={{ $json.CPF }}"
            }
          ]
        },
        "sendHeaders": true,
