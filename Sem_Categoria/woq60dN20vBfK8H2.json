        "name": "Remove Duplicates"
      },
      {
        "parameters": {
          "jsCode": "const items = $input.all();\n\nconst resultado = {};\n\nfor (const item of items) {\n  const nome = item.json.NOME;\n  const cpf = item.json.CPFCNPJ;\n  const telefone = item.json.TELEFONE;\n\n  if (!resultado[cpf]) {\n    resultado[cpf] = {\n      NOME: nome,\n      CPFCNPJ: cpf,\n      TELEFONES: []\n    };\n  }\n\n  // Evita telefone duplicado\n  if (!resultado[cpf].TELEFONES.includes(telefone)) {\n    resultado[cpf].TELEFONES.push(telefone);\n  }\n}\n\n// Converter para formato de saída do n8n\nreturn Object.values(resultado).map(item => ({ json: item }));"
        },
