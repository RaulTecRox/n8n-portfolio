</option>\n</select>\n                    </div>\n                    <div class=\"dados\">Espécie<br>\n                        <select id=\"selectEspecie\" type=\"text\" class=\"w336\" name=\"selectEspecie\">\n<option selected=\"selected\" value=\"\">Escolha</option>\n<option value=\"1\">1 - EMPRESTIMO PESSOAL</option>\n<option value=\"21\">21 - CB-COMPRA</option>\n<option value=\"22\">22 - CB-SAQUE</option>\n</select>\n                    </div>\n\n                    <div class=\"dados\">\n                        <input type=\"button\" value=\"Pesquisar\" class=\"botao botaoPadrao\" name=\"botaoPesquisar\" id=\"id1468\">\n                    </div>\n                </div>\n                <br class=\"clr\">\n\n                <div id=\"id146a\">\n                    <div id=\"painelOrgaos\">\n\n    <div id=\"divContentResultado\">\n        <span id=\"id1474\">\n    <div class=\"blocoDados itemVisivel\" id=\"id1475\">\n        <div id=\"painelResultado\">\n            <div class=\"destaqueTb\">\n                <span class=\"tituloTb\" id=\"id1476\">Resultado</span>\n                <span class=\"imgTb\">\n                    <input type=\"button\" name=\"contentResultado:painelOrgaos:contentResultado:orgaos:1:divResultados:painelResultado:btRecolher\" class=\"btRecolher\" id=\"id146d\">\n                </span>\n            </div>\n\n            <div id=\"divResultadoServidor\" class=\"itemVisivel\">\n                <div class=\"blocoDados2\" id=\"id1477\">\n                    <br class=\"clr\">\n                    <div class=\"dados\" style=\"width: 38%\">CPF - <span id=\"id1478\">057.612.108-86</span></div>\n                    <div class=\"dados\" style=\"width: 60%\">Nome - <span id=\"id1479\">ANTONIO JOSE DE OLIVEIRA FILHO</span></div>\n                    <br class=\"clr\">\n\n                    <div id=\"id147a\">\n                        <div class=\"dados\" style=\"width: 38%\">Órgão - <span id=\"id147b\">SMG - SP (PMSP)</span></div>\n               