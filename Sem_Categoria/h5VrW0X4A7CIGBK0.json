      "parameters": {
        "jsCode": "// Coleta os dados do nó $('APROVADOR')\nconst chamados = $('Ajusta campos').all();\n\n// Função para determinar a saudação com base no horário atual\nfunction obterSaudacao() {\n  const hora = new Date().getHours();\n  if (hora >= 6 && hora < 12) {\n    return \"Bom dia\";\n  } else if (hora >= 12 && hora < 18) {\n    return \"Boa tarde\";\n  } else {\n    return \"Boa noite\";\n  }\n}\n\n// Verifica se há dados e monta a mensagem\nif (chamados && chamados.length > 0 && chamados[0].json) {\n  const chamado = chamados[0].json; // Pega o primeiro item no formato correto\n  const saudacao = obterSaudacao(); // Obtém a saudação adequada\n\n  // Cria a mensagem para o aprovador informando o chamado aguardando aprovação\n  const mensagem = `${saudacao},\\n\\n` +\n    `O chamadinho da amizade número ${chamado.ID}, com o título \"${chamado.TITULO}\",\\n\\n` +\n    `O abençoado deste chamado é ${chamado.REQUERENTE}.\\n\\n` +\n    `Para mais detalhes, acesse o chamado no GLPI: ${chamado.URL}\\n\\n` +\n    `Atenciosamente,\\nTecnologia da Informação.`;\n\n  // Retorna a mensagem formatada como string JSON\n  return {\n    textMessage: {\n      msg: JSON.stringify(mensagem.trim())\n    }\n  };\n} else {\n  // Retorna uma mensagem padrão caso não haja dados\n  return {\n    textMessage: {\n      msg: JSON.stringify(\"Não foram encontrados dados do chamado aguardando aprovação.\")\n    }\n  };\n}\n"
      },
