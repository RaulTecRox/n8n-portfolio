    {
      "parameters": {
        "jsCode": "// Coleta os dados do nó $('MergePendente') e do nó $('If')\nconst dadosRequerente = $node[\"MergeAprovador\"].json;\nconst validacaoWhatsApp = $node[\"If1\"].json;\n\n// Função para determinar a saudação com base no horário atual\nfunction obterSaudacao() {\n  const hora = new Date().getHours();\n  if (hora >= 6 && hora < 12) {\n    return \"Bom dia\";\n  } else if (hora >= 12 && hora < 18) {\n    return \"Boa tarde\";\n  } else {\n    return \"Boa noite\";\n  }\n}\n\n// Verifica se há dados do requerente e da validação do WhatsApp\nif (dadosRequerente && validacaoWhatsApp) {\n  const requerente = dadosRequerente; // Dados do requerente\n  const whatsappValido = validacaoWhatsApp.exists;\n  const jid = validacaoWhatsApp.jid;\n  const numero = validacaoWhatsApp.number;\n\n  if (!whatsappValido) {\n    const saudacao = obterSaudacao(); // Obtém a saudação adequada\n\n    // Cria a mensagem informando que o número não possui WhatsApp, incluindo jid\n    const mensagem = `${saudacao}!\\n\\n` +\n      `O número telefônico ${numero} do Aprovador ${requerente.NOME} não possui WhatsApp.\\n\\n`;\n\n    // Retorna a mensagem formatada como string JSON\n    return {\n      textMessage: {\n        msg: JSON.stringify(mensagem.trim())\n      }\n    };\n  } else {\n    // Caso o número possua WhatsApp, retorna uma mensagem informativa\n    return {\n      textMessage: {\n        msg: JSON.stringify(\"O número telefônico possui WhatsApp.\")\n      }\n    };\n  }\n} else {\n  // Retorna uma mensagem padrão caso não haja dados suficientes\n  return {\n    textMessage: {\n      msg: JSON.stringify(\"Não foram encontrados dados para validação do WhatsApp.\")\n    }\n  };\n}\n"
      },
