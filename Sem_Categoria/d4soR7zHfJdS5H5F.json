    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst resultado = [];\n\nfor (const item of items) {\n  const data = item.json.data;\n\n  if (!data) continue;\n\n  const beneficiary_name = data.beneficiary_name || null;\n  const benefit_number = data.benefit_number || null;\n  const phone_number = data.zetra_benefit?.phone_number || null;\n\n  const margins = data.zetra_benefit?.margins || {};\n\n  // Se existir margem\n  const keys = Object.keys(margins);\n\n  if (keys.length > 0) {\n    for (const key of keys) {\n      const margin = margins[key];\n\n      resultado.push({\n        json: {\n          beneficiary_name,\n          benefit_number,\n          phone_number,\n          margin_code: margin.code || null,\n          description: margin.description || null,\n          available_value: margin.available_value\n            ? Number(margin.available_value)\n            : null\n        }\n      });\n    }\n  } else {\n    // Se não existir margem, ainda retorna dados básicos\n    resultado.push({\n      json: {\n        beneficiary_name,\n        benefit_number,\n        phone_number,\n        margin_code: null,\n        description: null,\n        available_value: null\n      }\n    });\n  }\n}\n\nreturn resultado;\n"
      },
