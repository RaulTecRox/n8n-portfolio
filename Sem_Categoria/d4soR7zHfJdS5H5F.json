    {
      "parameters": {
        "jsCode": "const html = $json.data;\n\nif (!html) {\n  throw new Error(\"HTML não encontrado\");\n}\n\n// Procura links no padrão /csv-.../file\nconst regex = /href=\"([^\"]*\\/csv-[^\"]*\\/file)\"/gi;\n\nlet match;\nlet encontrado = null;\n\nwhile ((match = regex.exec(html)) !== null) {\n  const url = match[1];\n\n  if (url.toLowerCase().includes(\"relacao-de-servidores-estatutarios\")) {\n    encontrado = url;\n    break;\n  }\n}\n\nif (!encontrado) {\n  throw new Error(\"Link de Relacao de Servidores Estatutarios não encontrado\");\n}\n\n// Garante URL absoluta\nif (!encontrado.startsWith(\"http\")) {\n  encontrado = \"https://repositorio.londrina.pr.gov.br\" + encontrado;\n}\n\nreturn [\n  {\n    json: {\n      csvUrl: encontrado\n    }\n  }\n];\n"
      },
