      "id": "081dd134-8773-4d66-9a54-e7b98e88ce95",
      "name": "Schedule Trigger"
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT\n\tlista_cpfs.cpf AS CPF,\n\tlista_raw.numero AS 'Numero Processo',\n\tlista_raw.numero_cnj AS 'Numero CNJ',\n\tlista_raw.requerente_1 AS 'Nome Requerente 1',\n\tDATE_FORMAT(lista_raw.data_consulta_robo, '%d/%m/%Y %H:%i:%s') AS 'Data Consulta'\nFROM\n\tlista_raw AS lista_raw \n\tINNER JOIN lista_cpfs AS lista_cpfs \n\tON lista_raw.id = lista_cpfs.id_lista_raw\nWHERE \n\tYEAR(lista_raw.data_consulta_robo) = YEAR(DATE_SUB(CURDATE(), INTERVAL 1 MONTH)) AND\n\tMONTH(lista_raw.data_consulta_robo) = MONTH(DATE_SUB(CURDATE(), INTERVAL 1 MONTH));\n",
        "options": {}
      },
      "type": "n8n-nodes-base.mySql",
      "typeVersion": 2.4,
      "position": [
        220,
        0
      ],
      "id": "a652e105-26cd-4485-81de-fb8d88c7854c",
      "name": "Get Mensal data",
      "credentials": {
