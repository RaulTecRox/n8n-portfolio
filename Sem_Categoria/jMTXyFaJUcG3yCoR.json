      "name": "Edit Fields"
    },
    {
      "parameters": {
        "jsCode": "const files = items.map(item => item.json);\n\n// Agrupar arquivos por VM e timestamp\nconst grouped = {};\nconst regex = /vzdump-(lxc|qemu)-(\\d+)-(\\d{4}_\\d{2}_\\d{2}-\\d{2}_\\d{2}_\\d{2})/;\n\nfiles.forEach(file => {\n  const match = file.name.match(regex);\n  if (!match) return;\n\n  const type = match[1]; // lxc ou qemu\n  const vm = match[2];   // ex: \"103\" ou \"100\"\n  const ts = match[3];   // ex: \"2025_08_21-18_00_03\"\n\n  const vmKey = `${type}-${vm}`;\n  if (!grouped[vmKey]) grouped[vmKey] = {};\n  if (!grouped[vmKey][ts]) grouped[vmKey][ts] = [];\n  grouped[vmKey][ts].push(file);\n});\n\nconst toDelete = [];\n\nfor (const vmKey in grouped) {\n  // Obter todos os timestamps do VM e ordenar do mais recente para o mais antigo\n  const timestamps = Object.keys(grouped[vmKey]).sort((a, b) => {\n    const dateA = new Date(grouped[vmKey][a][0].modifyTime);\n    const dateB = new Date(grouped[vmKey][b][0].modifyTime);\n    return dateB - dateA; // mais recente primeiro\n  });\n\n  // Manter apenas os 2 backups mais recentes\n  const oldTimestamps = timestamps.slice(2);\n\n  oldTimestamps.forEach(ts => {\n    toDelete.push(...grouped[vmKey][ts]);\n  });\n}\n\nreturn toDelete.map(f => ({ json: f }));\n"
      },
