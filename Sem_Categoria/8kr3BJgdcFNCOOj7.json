    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO argus_calls (\n    idLigacao, dataHoraLigacao, idTronco, nrLead, tipoAgendaLigacao, tipoLigacao,\n    idStatusLigacao, resultadoLigacao, tempoSegundos, telefone, idLote, lote,\n    nomeCliente, dataImportacao, cpfCnpj, codCliente, idGrupoUsuario, grupoOrigem,\n    idUsuario, usuarioOperador, idPlanPopup, statusAtendimento, tipoAgenda,\n    idTabulacao, tabulacao, categoriaTabulacao, historico, state_id)\nVALUES\n    {{ $('Loop Over Items').first().json.result }}\nON DUPLICATE KEY UPDATE\n    dataHoraLigacao = VALUES(dataHoraLigacao),\n    idTronco = VALUES(idTronco),\n    nrLead = VALUES(nrLead),\n    tipoAgendaLigacao = VALUES(tipoAgendaLigacao),\n    tipoLigacao = VALUES(tipoLigacao),\n    idStatusLigacao = VALUES(idStatusLigacao),\n    resultadoLigacao = VALUES(resultadoLigacao),\n    tempoSegundos = VALUES(tempoSegundos),\n    telefone = VALUES(telefone),\n    idLote = VALUES(idLote),\n    lote = VALUES(lote),\n    nomeCliente = VALUES(nomeCliente),\n    dataImportacao = VALUES(dataImportacao),\n    cpfCnpj = VALUES(cpfCnpj),\n    codCliente = VALUES(codCliente),\n    idGrupoUsuario = VALUES(idGrupoUsuario),\n    grupoOrigem = VALUES(grupoOrigem),\n    idUsuario = VALUES(idUsuario),\n    usuarioOperador = VALUES(usuarioOperador),\n    idPlanPopup = VALUES(idPlanPopup),\n    statusAtendimento = VALUES(statusAtendimento),\n    tipoAgenda = VALUES(tipoAgenda),\n    idTabulacao = VALUES(idTabulacao),\n    tabulacao = VALUES(tabulacao),\n    categoriaTabulacao = VALUES(categoriaTabulacao),\n    historico = VALUES(historico),\n    state_id = VALUES(state_id);\n",
        "options": {}
