    {
      "parameters": {
        "jsCode": "const calls = $('If exists regs').first().json.ligacoesDetalhadas;\nconst states = $('Select all states').all();\nconst blockSize = 1000;\nconst quantity = calls.length;\nconst blocks = Math.ceil(quantity / blockSize);\n\nlet result = [];\n\nfunction getDdd(number) {\n  const phoneNumberStr = number.toString();\n  return phoneNumberStr.slice(0, 2)\n}\n\nfunction getStateId(number) {\n  const ddd = getDdd(number);\n  const state = states.find(state => state.json.ddds.includes(ddd));\n  return state ? state.json.id : undefined  \n}\n\nfunction nuuabled(item) {\n  if (typeof(item) == \"string\") {\n      if (item != \"\") {\n          return `'${item}'`;\n      }\n      return \"NULL\";\n  }\n\n  if (typeof(item) == \"undefined\") {\n      return \"NULL\";\n  }\n\n  return item;\n\n}\n\nfor (let i = 0; i < blocks; i++) {\n  const start = i * blockSize;\n  const end = start + blockSize;\n  const block = calls.slice(start, end);\n  const insertString = block.map((item) => {\n      return `(` +\n      `${nuuabled(item.idLigacao)},` +\n      `${nuuabled(new Date(item.dataHoraLigacao).toISOString().split('T')[0] + ' ' + new Date(item.dataHoraLigacao).toTimeString().split(' ')[0].slice(0, -3) + ':00')},` +\n      `${nuuabled(item.idTronco)},` +\n      `${nuuabled(item.nrLead)},` +\n      `${nuuabled(item.tipoAgendaLigacao)},` +\n      `${nuuabled(item.tipoLigacao)},` +\n      `${nuuabled(item.idStatusLigacao)},` +\n      `${nuuabled(item.resultadoLigacao)},` +\n      `${nuuabled(item.tempoSegundos)},` +\n      `${nuuabled(item.telefone)},` +\n      `${nuuabled(item.idLote)},` +\n      `${nuuabled(item.lote)},` +\n      `${nuuabled(item.nomeCliente)},` +\n      `${nuuabled(new Date(item.dataImportacao).toISOString().split('T')[0] + ' ' + new Date(item.dataImportacao).toTimeString().split(' ')[0].slice(0, -3) + ':00')},` +\n      `${nuuabled(item.cpfCnpj)},` +\n      `${nuuabled(item.codCliente)},` +\n      `${nuuabled(item.idGrupoUsuario)},` +\n      `${nuuabled(item.grupoOrigem)},` +\n      `${nuuabled(item.idUsuario)},` +\n      `${nuuabled(item.usuarioOperador)},` +\n      `${nuuabled(item.idPlanPopup)},` +\n      `${nuuabled(item.statusAtendimento)},` +\n      `${nuuabled(item.tipoAgenda)},` +\n      `${nuuabled(item.idTabulacao)},` +\n      `${nuuabled(item.tabulacao)},` +\n      `${nuuabled(item.categoriaTabulacao)},` +\n      `${nuuabled(item.historico)},` +\n      `${nuuabled(getStateId(item.telefone))}`+\n      `)`;\n  }).join(',');\n\n  result.push(insertString);\n}\n\nreturn {result: result};"
      },
