    {
      "parameters": {
        "jsCode": "// Pega a string JSON que está dentro de \"output\"\nconst raw = $json.output;\n\n// Converte a string para objeto JavaScript\nlet data;\ntry {\n  data = JSON.parse(raw);\n} catch (err) {\n  throw new Error(\"Erro ao converter JSON: \" + err.message);\n}\n\n// Função para separar rua e número\nfunction splitEndereco(endereco) {\n  if (!endereco) return { rua: \"\", numero: \"\" };\n  const partes = endereco.split(\",\");\n  return {\n    rua: partes[0]?.trim() || \"\",\n    numero: partes[1]?.trim() || \"\"\n  };\n}\n\nconst seen = new Set();\nconst ajustado = [];\n\nfor (const item of data) {\n  const { rua, numero } = splitEndereco(item.Endereco);\n\n  const id = `${item.Nome}|${rua}|${numero}`;\n  if (seen.has(id)) continue; // remove duplicados\n  seen.add(id);\n\n  ajustado.push({\n    Nome: item.Nome?.trim(),\n    Rua: rua,\n    Numero: numero,\n    Bairro: item.Bairro?.trim(),\n    Cidade: item.Cidade?.trim()\n  });\n}\n\n// Retorna cada registro como item separado do n8n\nreturn ajustado.map(r => ({ json: r }));\n"
      },
