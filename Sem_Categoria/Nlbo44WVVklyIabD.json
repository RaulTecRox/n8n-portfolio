    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst resultado = [];\n\nfor (const item of items) {\n\n  const rows = item.json.rows || [];\n  if (!rows.length) continue;\n\n  const data = rows[0];\n\n  const beneficiary_name = data.beneficiary_name || null;\n  const document = data.document || null;\n\n  const consultMargin = data.cip_benefit?.consult_margin || {};\n\n  function convertToNumber(value) {\n    if (value === null || value === undefined) return null;\n\n    const numericValue = Number(value);\n    if (isNaN(numericValue)) return null;\n\n    return Number((numericValue / 100).toFixed(2));\n  }\n\n  function formatBR(value) {\n    if (value === null) return null;\n\n    return value.toLocaleString('pt-BR', {\n      minimumFractionDigits: 2,\n      maximumFractionDigits: 2\n    });\n  }\n\n  function getEmploymentDescription(type) {\n    const map = {\n      1: \"Aposentado\",\n      6: \"Pensionista\",\n      7: \"Efetivo\",\n      8: \"Estab. Constit\",\n      9: \"Pensão Especial\"\n    };\n\n    return map[type] || \"Não identificado\";\n  }\n\n  const availableMargin = convertToNumber(\n    consultMargin.available_margin_in_cents\n  );\n\n  const employment_type = consultMargin.employment_type ?? null;\n\n  resultado.push({\n    json: {\n      beneficiary_name,\n      document,\n\n      agency_name: consultMargin.agency_name || null,\n      employment_type,\n      employment_description: getEmploymentDescription(employment_type),\n      provision_number: consultMargin.provision_number || null,\n\n      available_margin_value_rcc: availableMargin,\n      available_margin_display_rcc: formatBR(availableMargin)\n    }\n  });\n\n}\n\nreturn resultado;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        704,
        672
      ],
