    {
      "parameters": {
        "jsCode": "const webhook = $('Webhook').first().json.body\nconst message = $('Selecionando mensagem1').first().json\nconst instance = $('Sorteia uma caixa de saida').first().json\n\nreturn {\n  \"evolutionNameInstance\": instance[\"instance_name\"],\n  \"evolutionUrlSendMessage\": instance[\"instance_endpoint\"].concat(\"/message/sendText/\", instance[\"instance_name\"]),\n  \"evolutionUrlTestConnection\": instance[\"instance_endpoint\"].concat(\"/instance/connectionState/\", instance[\"instance_name\"]),\n  \"evolutionUrlTestWhatsapp\": instance[\"instance_endpoint\"].concat(\"/chat/whatsappNumbers/\", instance[\"instance_name\"]),\n  \"evolutionApiKey\": instance[\"instance_apikey\"],\n  \"clientPhone\": \"55\".concat(webhook[\"telefone\"]),\n  \"clientMessage\": message[\"messages_message\"]\n}\n"
      },
