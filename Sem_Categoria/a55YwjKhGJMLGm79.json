      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT \n\tinstances.name AS instance_name,\n\tinstances.endpoint AS instance_endpoint,\n\tinstances.apikey AS instance_apikey,\n\tbranchs.name AS branchs_name\nFROM instances AS instances \nINNER JOIN branchs AS branchs\nON instances.external_group_id = branchs.id\nWHERE instances.active = 1 AND instances.send = 'evolution-api' AND branchs.external_group_id = {{ $('Webhook').first().json.body.idGrupoUsuario}}\nORDER BY RAND()\nLIMIT 1;",
        "options": {}
      },
