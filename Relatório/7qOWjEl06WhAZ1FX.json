      {
        "parameters": {
          "jsCode": "// Função para formatar a data no formato 'Mês/Ano'\nfunction getLastMonth() {\n  const currentDate = new Date();\n  currentDate.setMonth(currentDate.getMonth() - 1); // Mover para o mês anterior\n  const month = currentDate.toLocaleString('pt-BR', { month: 'long' });\n  const year = currentDate.getFullYear();\n  return `${month} de ${year}`;\n}\n\n// Função para formatar valores em R$\nfunction formatCurrency(value) {\n  return new Intl.NumberFormat('pt-BR', { style: 'currency', currency: 'BRL' }).format(value);\n}\n\n// Obtém todos os itens de entrada\nconst inputData = $input.all();\n\n// Verifica se há dados para processar\nif (inputData.length > 0) {\n  // Calcular o mês anterior\n  const lastMonth = getLastMonth();\n\n  // Gerar HTML\n  let html = `\n  <!DOCTYPE html>\n  <html lang=\"pt-BR\">\n  <head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Relatório de Precatórios Vendidos</title>\n    <style>\n      body {\n        font-family: Arial, sans-serif;\n        margin: 20px;\n      }\n      table {\n        width: 100%;\n        border-collapse: collapse;\n        margin-top: 20px;\n      }\n      th, td {\n        padding: 8px;\n        text-align: left;\n        border: 1px solid #ddd;\n      }\n      th {\n        background-color: #f2f2f2;\n      }\n      .highlight {\n        background-color: #e7f7e7;\n      }\n      .signature {\n        margin-top: 30px;\n        text-align: left;\n        position: absolute;\n        bottom: 20px;\n        left: 20px;\n      }\n      .signature img {\n        width: 450px; /* Tamanho triplicado da imagem */\n        height: auto;\n      }\n    </style>\n  </head>\n  <body>\n    <p>Olá Daniel,</p>\n    <p>Segue abaixo o relatório dos precatórios vendidos que o RPA localizou no mês de <strong>${lastMonth}</strong>:</p>\n    \n    <table>\n      <thead>\n        <tr>\n          <th>Procedimento</th>\n          <th>Número</th>\n          <th>Requerente</th>\n          <th>Valor Solicitado</th>\n          <th>Valor Bruto</th>\n          <th>Comissão Empresa Bruto</th>\n          <th>Comissão Empresa Líquido</th>\n          <th>Colaborador</th>\n          <th>Pago</th>\n        </tr>\n      </thead>\n      <tbody>`;\n\n  // Itera sobre todos os itens de entrada\n  inputData.forEach((item, index) => {\n    // Garantir que os valores estejam disponíveis antes de tentar exibi-los\n    const comissaoEmpresaBruto = formatCurrency(item.json['COMISSÃO_EMPRESA_BRUTO'] || 0);\n    const comissaoEmpresaLiquido = formatCurrency(item.json['COMISSÃO_EMPRESA_LÍQUIDO'] || 0);\n    const colaborador = item.json['COLABORADOR'] || 'Não disponível';\n    const valorSolicitado = formatCurrency(item.json.valor_solicitado || 0);\n    const valorBruto = formatCurrency(item.json.BRUTO || 0);\n\n    // Gerar as linhas da tabela com os dados dos precatórios\n    html += `\n      <tr class=\"${index % 2 === 0 ? 'highlight' : ''}\">\n        <td>${item.json.procedimento}</td>\n        <td>${item.json.numero}</td>\n        <td>${item.json.requerente}</td>\n        <td>${valorSolicitado}</td>\n        <td>${valorBruto}</td>\n        <td>${comissaoEmpresaBruto}</td>\n        <td>${comissaoEmpresaLiquido}</td>\n        <td>${colaborador}</td>\n        <td>${item.json.PAGO}</td>\n      </tr>\n    `;\n  });\n\n  html += `\n      </tbody>\n    </table>\n\n    <p>Atenciosamente,</p>\n\n    <div class=\"signature\">\n      <img src=\"https://drive.google.com/uc?export=download&id=1PxDpYA9hItRyK_y9ksCTQgEJ0yJ2QR7H\" alt=\"Assinatura\">\n    </div>\n  </body>\n  </html>\n  `;\n\n  // Criação do assunto para o email\n  const subject = `Relatório de Precatórios Vendidos - ${lastMonth}`;\n\n  // Retorna o HTML e o assunto como saída\n  return [\n    {\n      json: {\n        emailBody: html,\n        subject: subject\n      }\n    }\n  ];\n} else {\n  throw new Error(\"Nenhum dado encontrado no Merge ou dados mal formatados.\");\n}\n"
        },
