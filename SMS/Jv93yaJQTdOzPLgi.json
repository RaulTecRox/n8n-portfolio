    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO contacts (external_group_id, phone, first_name, second_name, created_by, send_per)\nVALUES \n    ((SELECT id FROM branchs WHERE active = 1 AND external_group_id = '{{ $json.idGrupoUsuario }}'), '{{ $json.telefone }}', '{{ $json.firtName }}', '{{ $json.lastName }}', 'rpa.contacts', '[\"sms\"]')\nON DUPLICATE KEY UPDATE\n    external_group_id = (SELECT id FROM branchs WHERE active = 1 AND external_group_id = '{{ $json.idGrupoUsuario }}'),\n    first_name = VALUES(first_name),\n    second_name = VALUES(second_name),\n    created_by = VALUES(created_by),\n    send_per = VALUES(send_per)",
        "options": {}
