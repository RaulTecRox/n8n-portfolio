      {
        "parameters": {
          "jsCode": "let entrada = items[0].json.content;\nlet mensagemFormatada = '';\n\ntry {\n  // Tentamos transformar a string em objeto JSON\n  const parsed = JSON.parse(entrada);\n\n  // Se conseguir, formata como mensagem estruturada\n  mensagemFormatada = `\n📄 *Detalhes da Proposta* 📄\n\n🏦 Banco: ${parsed.nome_banco || 'Não informado'}\n📍 Fase: ${parsed.descricao_fase || 'Não informado'}\n📌 Status: ${parsed.Status || 'Não informado'}\n📑 Código AF: ${parsed.af_codigo || 'Não informado'}\n📃 Contrato: ${parsed.contrato || 'Não informado'}\n  `.trim();\n\n} catch (error) {\n  // Se não for JSON, trata como texto simples e só remove aspas ou chaves\n  mensagemFormatada = entrada\n    .replace(/^\"|\"$/g, '')    // remove aspas do começo/fim se tiver\n    .replace(/[{}\"]/g, '')    // remove chaves e aspas internas\n    .trim();\n}\n\nreturn [{ json: { mensagem: mensagemFormatada } }];\n"
        },
