      {
        "parameters": {
          "jsCode": "// Pega e interpreta o content\nlet raw = $json.content;\nlet data;\n\ntry {\n  data = JSON.parse(raw);\n} catch (e) {\n  data = {};\n}\n\n// Captura segura dos campos\nconst nome = data.full_name || \"\";\nconst proposta = data.proposta_lead || \"\";\nconst cpf = data.cpf || \"\";\nconst phone = data.phone || \"\";\nconst offer = data.real_offer ? Number(data.real_offer).toFixed(2) : null;\nconst parcela = data.installment_value ? Number(data.installment_value).toFixed(2) : null;\n\n// Monta a mensagem\nlet msg = `Resumo rápido do atendimento:\\n`;\n\nif (nome) msg += `• Cliente: ${nome}\\n`;\nif (cpf) msg += `• CPF: ${cpf}\\n`;\nif (phone) msg += `• Telefone/WhatsApp: ${phone}\\n`;\n\nif (offer || parcela) {\n  msg += `• Simulação enviada:\\n`;\n  if (offer) msg += `  - Valor aproximado liberado: R$ ${offer}\\n`;\n  if (parcela) msg += `  - Parcela estimada: R$ ${parcela}\\n`;\n}\n\nif (proposta) {\n  msg += `\\nContexto do atendimento:\\n${proposta}`;\n}\n\n// Retorno\nreturn [{ json: { message: msg } }];\n"
        },
