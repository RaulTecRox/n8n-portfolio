    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\n// Objeto para armazenar clientes agrupados pelo CPF\nconst clientes = {};\n\nitems.forEach(item => {\n    const cpf = item.json[\"CPFCNPJ\"];\n    const telefone = item.json[\"TELEFONE\"];\n    \n    if (!clientes[cpf]) {\n        clientes[cpf] = {\n            \"NOME\": item.json[\"NOME\"],\n            VALOR: item.json[\"VALOR\"],\n            CPFCNPJ: item.json[\"CPFCNPJ\"],\n            ENDERECO: item.json[\"ENDERECO\"],\n            NUMERO: item.json[\"NUMERO\"],\n            COMPLEMENTO: item.json[\"COMPLEMENTO\"],\n            BAIRRO: item.json[\"BAIRRO\"],\n            CEP: item.json[\"CEP\"],\n            CIDADE: item.json[\"CIDADE\"],\n            UF: item.json[\"UF\"],\n            EMAILS: item.json[\"EMAILS\"],\n            TELEFONE1: null,\n            TELEFONE2: null,\n            TELEFONE3: null,\n            TELEFONE4: null,\n            TELEFONE5: null,\n            TELEFONES: new Set()\n        };\n    }\n    \n    // Adiciona o telefone apenas se ainda não estiver armazenado\n    if (!clientes[cpf].TELEFONES.has(telefone)) {\n        clientes[cpf].TELEFONES.add(telefone);\n        \n        for (let i = 1; i <= 5; i++) {\n            if (!clientes[cpf][`TELEFONE${i}`]) {\n                clientes[cpf][`TELEFONE${i}`] = telefone;\n                break;\n            }\n        }\n    }\n});\n\n// Remove a propriedade Set antes de retornar os dados\nreturn Object.values(clientes).map(cliente => {\n    delete cliente.TELEFONES;\n    return { json: cliente };\n});\n"
      },
